# ==========================================
# Cluster Configuration
# ==========================================

# Empty = use system username as prefix
cluster_name_prefix = ""

region             = "us-east" # us-east, us-central, eu-west, ap-south, etc.
kubernetes_version = "1.34"
ha_control_plane   = false # true = adds ~$60/month

# ==========================================
# Node Pools (cost-optimized defaults: 1 node, ~$24/mo)
# ==========================================
#
# Cost ladder (per node, monthly):
#   g6-standard-1  -> 1 vCPU,  2GB RAM   ~$24
#   g6-standard-2  -> 2 vCPU,  4GB RAM   ~$36
#   g6-standard-4  -> 4 vCPU,  8GB RAM   ~$72
#   g6-standard-6  -> 6 vCPU, 16GB RAM   ~$144
#
# NOTE: Linode LKE does not offer spot/preemptible instances.

node_pools = [
  {
    type  = "g6-standard-1"
    count = 1
    autoscaler = {
      min = 1
      max = 3
    }
  }
]

tags = ["kubernetes", "dev"]

# ==========================================
# Firewall
# ==========================================
# IMPORTANT: Replace 0.0.0.0/0 with your IP for production.
# Get your IP: curl ifconfig.me

firewall_enabled          = true
firewall_enable_nodeports = true
allowed_kubectl_ips       = ["0.0.0.0/0"] # kubectl API + NodePorts
allowed_monitoring_ips    = ["0.0.0.0/0"] # Grafana / Prometheus UIs

# ==========================================
# Add-ons (opt-in to save cost)
# ==========================================

# Metrics Server: lightweight, enables `kubectl top` and HPA
install_metrics_server = true

# Monitoring: kube-prometheus-stack (Prometheus + Grafana + Alertmanager)
# Disabled by default. Enable for observability; uses Linode block storage.
install_monitoring = false

# Use ephemeral (emptyDir) storage instead of PVCs - free, but data lost on restart
monitoring_use_ephemeral_storage = false

monitoring_namespace      = "monitoring"
grafana_admin_password    = "admin" # CHANGE THIS
prometheus_retention      = "7d"
prometheus_storage_size   = "20Gi"
grafana_storage_size      = "5Gi"
alertmanager_storage_size = "2Gi"

# OpenCost: cost monitoring (requires install_monitoring = true)
install_opencost   = false
opencost_namespace = "opencost"
