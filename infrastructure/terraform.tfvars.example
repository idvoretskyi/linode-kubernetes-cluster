# Cluster Name Configuration
# Leave empty to use system username as prefix
cluster_name_prefix = "" # Will use whoami if not set (e.g., "john-lke")

# Cluster Configuration
region              = "us-east"      # Available regions: us-east, us-central, eu-west, ap-south, etc.
kubernetes_version  = "1.34"         # Latest stable K8s version
ha_control_plane    = false          # Set true for HA control plane ($60/month extra)

# Node Pools Configuration
node_pools = [
  {
    type  = "g6-standard-1" # 1 vCPU, 2GB RAM (~$24/month per node)
    count = 3               # Initial node count
    autoscaler = {
      min = 1               # Minimum nodes (for cost savings)
      max = 5               # Maximum nodes (for scaling)
    }
  }
]

# Firewall Configuration
firewall_enabled          = true
firewall_enable_nodeports = true

# IMPORTANT: Security - Replace with your actual IP addresses for production!
# Get your IP: curl ifconfig.me
# Format: ["YOUR_IP/32"] or ["YOUR_IP/32", "OFFICE_IP/32"]
allowed_kubectl_ips    = ["0.0.0.0/0"] # Who can access kubectl API (port 443)
allowed_monitoring_ips = ["0.0.0.0/0"] # Who can access monitoring UIs
firewall_allowed_ips   = ["0.0.0.0/0"] # Who can access NodePorts

firewall_inbound_policy  = "ACCEPT" # Accept for internal cluster traffic
firewall_outbound_policy = "ACCEPT" # Allow all outbound traffic

# Additional Tags
tags = ["kubernetes", "production"] # Add custom tags here

# Monitoring Stack (Prometheus + Grafana + Alertmanager)
install_monitoring      = true       # Set false to skip monitoring installation
monitoring_namespace    = "monitoring"
grafana_admin_password  = "admin"    # CHANGE THIS IN PRODUCTION!
prometheus_retention    = "15d"      # How long to keep metrics
prometheus_storage_size = "50Gi"     # Persistent storage for Prometheus
grafana_storage_size    = "10Gi"     # Persistent storage for Grafana

# Metrics Server (Required for kubectl top and HPA)
install_metrics_server = true        # Enables kubectl top nodes/pods

# OpenCost (Kubernetes cost monitoring and optimization)
install_opencost = true              # Install OpenCost for cost visibility
